#
# Production Environment Configuration
# Baileys WhatsApp API with Odoo ChatRoom Integration
#

# --- Database Configuration ---
# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://app:app@db:5432/app

# --- Next.js / Authentication ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET
# Public URL for authentication callbacks
AUTH_URL=https://your-domain.com
# Public application URL
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- WhatsApp Session Storage ---
# Directory for WhatsApp session data (multi-tenant)
# Docker volume should be mounted to this path
WHATSAPP_SESSION_ROOT=/app/sessions

# --- WhatsApp Media Storage ---
# Directory for cached inbound media files
# Must be accessible via public URL for Odoo
WHATSAPP_MEDIA_ROOT=/app/wa-media-cache
# Public base URL for media files (served by Next.js /api/media/[id])
# This URL must be accessible from Odoo servers
MEDIA_PUBLIC_BASE_URL=https://your-domain.com/api/media

# --- Odoo Webhook Configuration ---
# Odoo instance URL (where webhook events will be posted)
# Format: https://your-odoo.com
ODOO_BASE_URL=https://your-odoo.com

# Webhook endpoint path (appended to ODOO_BASE_URL)
# Default: /acrux_webhook/whatsapp_connector
ODOO_WEBHOOK_PATH=/acrux_webhook/whatsapp_connector

# Webhook retry configuration
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=1000
WEBHOOK_TIMEOUT_MS=10000

# Dead Letter Queue (DLQ) for failed webhooks
# Set to 'true' to enable DLQ logging
ENABLE_WEBHOOK_DLQ=true
# Directory for DLQ logs
WEBHOOK_DLQ_PATH=/app/logs/webhook-dlq

# --- Odoo API Connector Configuration ---
# These credentials are set in Odoo: ChatRoom → Connectors → apichat.io
# Token used for authenticating Odoo → Baileys API requests
ODOO_API_TOKEN=your-odoo-api-token
# Connector UUID (Account ID in Odoo connector config)
ODOO_CONNECTOR_UUID=your-connector-uuid

# --- Payment Gateway (SSLCommerz) ---
# Credentials from https://developer.sslcommerz.com/
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password
# Set to 'true' for live gateway, 'false' for sandbox
SSLCOMMERZ_IS_LIVE=true

# --- Application Settings ---
# Node environment (production | development | test)
NODE_ENV=production
# Application port (internal container port)
PORT=3000
# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# --- Docker PostgreSQL (for docker-compose.yml) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
POSTGRES_DB=app
# External port mapping for PostgreSQL (host:container)
POSTGRES_PORT=5432

# --- Health Check Configuration ---
# Health check endpoint timeout (milliseconds)
HEALTH_CHECK_TIMEOUT=5000
# Enable detailed health check response
HEALTH_CHECK_DETAILED=false

# --- Rate Limiting ---
# API rate limit per IP (requests per minute)
API_RATE_LIMIT=60
# Webhook rate limit per tenant (requests per minute)
WEBHOOK_RATE_LIMIT=100

# --- Session Management ---
# Auto-reconnect on WhatsApp disconnect
AUTO_RECONNECT=true
# Session keepalive interval (milliseconds)
SESSION_KEEPALIVE_INTERVAL=30000

# --- Security ---
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://your-odoo.com,https://your-domain.com
# Enable request logging
ENABLE_REQUEST_LOGGING=true

# --- Monitoring & Metrics ---
# Enable Prometheus metrics endpoint
ENABLE_METRICS=true
# Metrics endpoint path
METRICS_ENDPOINT=/api/metrics

# --- Backup Configuration ---
# Automated backup directory
BACKUP_PATH=/app/backups
# Backup retention days
BACKUP_RETENTION_DAYS=30
