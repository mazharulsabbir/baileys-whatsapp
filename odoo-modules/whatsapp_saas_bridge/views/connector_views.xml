<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_saas_whatsapp_connector_form" model="ir.ui.view">
        <field name="name">saas.whatsapp.connector.form</field>
        <field name="model">saas.whatsapp.connector</field>
        <field name="arch" type="xml">
            <form string="SaaS WhatsApp Connector">
                <header>
                    <button name="action_ping_saas" type="object" string="Check SaaS status" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="active"/>
                    </group>
                    <group string="SaaS credentials">
                        <field name="saas_base_url" placeholder="https://your-saas.example.com"/>
                        <field name="api_key" password="True"/>
                    </group>
                    <group string="Inbound webhook (paste URL into SaaS dashboard)">
                        <field name="webhook_verify_secret" password="True"/>
                        <field name="hook_token" readonly="1"/>
                        <field name="webhook_url_display" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Conversations">
                            <field name="conversation_ids" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="wa_chat_id"/>
                                    <field name="last_message_at"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_saas_whatsapp_connector_list" model="ir.ui.view">
        <field name="name">saas.whatsapp.connector.list</field>
        <field name="model">saas.whatsapp.connector</field>
        <field name="arch" type="xml">
            <list string="SaaS WhatsApp Connectors">
                <field name="name"/>
                <field name="saas_base_url"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_saas_whatsapp_connector" model="ir.actions.act_window">
        <field name="name">SaaS WhatsApp</field>
        <field name="res_model">saas.whatsapp.connector</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
