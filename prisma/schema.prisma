generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String                  @id @default(cuid())
  email          String                  @unique
  passwordHash   String
  name           String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  payments       Payment[]
  entitlement    Entitlement?
  integration    IntegrationCredential?
  odooGateway    OdooGatewayCredential?
  apiUsageEvents ApiUsageEvent[]
  odooWebhookDlq OdooWebhookDeadLetter[]
}

/// Odoo ChatRoom connector credentials (gateway headers token + client_id).
model OdooGatewayCredential {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectorUuid  String   @unique
  tokenHash      String
  tokenPrefix    String   @default("")
  /// Full POST URL registered via Odoo config_set (acrux_webhook).
  odooWebhookUrl String?
  configSetInfo  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

/// Failed POST to Odoo acrux_webhook after retries (manual replay from dashboard).
model OdooWebhookDeadLetter {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookUrl  String
  payload     Json
  lastError   String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, resolvedAt])
  @@index([createdAt])
}

/// Cached inbound WA media file on disk; served at /api/public/wa-media/[id] for Odoo `url` field.
model WaMediaArtifact {
  id         String   @id @default(cuid())
  userId     String
  mimeType   String
  fileName   String
  byteLength Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Append-only log of integration API calls (messages, status) for dashboard analytics.
model ApiUsageEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  route     String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// Machine-to-machine API key + outbound webhook settings (Odoo / automation).
model IntegrationCredential {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyHash     String
  apiKeyPrefix   String   @default("")
  webhookUrl     String?
  /// Shared secret for HMAC-SHA256 of JSON body when POSTing to webhookUrl (stored server-side).
  webhookSecret  String?
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Entitlement {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planSlug   String
  status     String
  validUntil DateTime
  updatedAt  DateTime @updatedAt
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tranId     String   @unique
  valId      String?
  amount     String
  currency   String
  status     String
  planSlug   String?
  rawPayload Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
