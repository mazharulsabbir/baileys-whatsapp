# WhatsApp Session Configuration
SESSION_NAME=whatsapp_session

# Authentication Method: 'qr' or 'pairing'
# qr - Scan QR code with WhatsApp mobile app
# pairing - Use pairing code (enter phone number below)
AUTH_METHOD=qr

# Phone number for pairing code authentication (include country code, no + sign)
# Example: 1234567890 for US number
PHONE_NUMBER=

# Browser Configuration (for WhatsApp Web emulation)
BROWSER_NAME=Chrome
BROWSER_VERSION=120.0.0
BROWSER_OS=Mac OS

# Sync full chat history (true/false)
# Set to true to download complete chat history
SYNC_FULL_HISTORY=false

# Print QR code in terminal (true/false)
PRINT_QR=true

# Log Level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Auto-reconnect on disconnect (true/false)
AUTO_RECONNECT=true

# Bot Command Prefix
COMMAND_PREFIX=!

# Admin phone numbers (comma-separated, for bot administration)
ADMIN_NUMBERS=
