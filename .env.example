#
# --- Web / SaaS (Next.js, Postgres, SSLCommerz) ---
#
# Local dev (Next on host, Postgres on host or port-forward). For Docker Compose web container, compose overrides host to `db` — keep localhost here for non-Docker runs.
DATABASE_URL=postgresql://odoo:123456@localhost:5432/whatsapp
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL for links and Odoo inbound media `url` fields; must be reachable by Odoo servers in production.
WHATSAPP_SESSION_ROOT=./sessions
# Uncomment to pull old messages on reconnect (heavy). Same flag as SYNC_FULL_HISTORY in src/config.
# SYNC_FULL_HISTORY=true
# Optional: directory for cached inbound media (default ./wa-media-cache). Ignored .gitignore folder.
# WHATSAPP_MEDIA_ROOT=
#
# Odoo: generate API key + webhook secret in Dashboard → "Odoo / API integration" after `prisma migrate` (IntegrationCredential table).
#

# Sandbox / live credentials from https://developer.sslcommerz.com/ (Registration → My Stores)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
# true = live gateway, false = sandbox
SSLCOMMERZ_IS_LIVE=false

# Optional: local testing without SSLCommerz (npm run dev only — ignored when NODE_ENV=production / Docker prod image)
# DEV_SKIP_SSLCOMMERZ=true

# Docker Compose (optional)
# POSTGRES_USER=app
# POSTGRES_PASSWORD=app
# POSTGRES_DB=app
# WEB_PORT=3000

# --- Legacy CLI bot (src/index.ts) ---
# WhatsApp Session Configuration
SESSION_NAME=whatsapp_session

# Authentication Method: 'qr' or 'pairing'
# qr - Scan QR code with WhatsApp mobile app
# pairing - Use pairing code (enter phone number below)
AUTH_METHOD=qr

# Phone number for pairing code authentication (include country code, no + sign)
# Example: 1234567890 for US number
PHONE_NUMBER=

# Browser Configuration (for WhatsApp Web emulation)
BROWSER_NAME=Chrome
BROWSER_VERSION=120.0.0
BROWSER_OS=Mac OS

# Sync full chat history (true/false)
# Set to true to download complete chat history
SYNC_FULL_HISTORY=false

# Print QR code in terminal (true/false)
PRINT_QR=true

# Log Level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Auto-reconnect on disconnect (true/false)
AUTO_RECONNECT=true

# Bot Command Prefix
COMMAND_PREFIX=!

# Admin phone numbers (comma-separated, for bot administration)
ADMIN_NUMBERS=
